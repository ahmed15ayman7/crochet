# MongoDB connection string (Prisma)
#
# The database NAME is required as a path segment after the host (before "?").
# Wrong:  ...mongodb.net/?retryWrites=true
# Right:  ...mongodb.net/my_app_db?retryWrites=true
#
# Atlas (SRV) — replace USER, PASSWORD, CLUSTER, and DATABASE:
DATABASE_URL="mongodb+srv://USER:PASSWORD@cluster0.wtq5rv2.mongodb.net/DATABASE?retryWrites=true&w=majority&appName=Cluster0"
#
# If your Atlas password contains @ # / : etc., URL-encode it (e.g. @ → %40).
# See: https://www.prisma.io/docs/orm/reference/connection-urls

# Local MongoDB example:
# DATABASE_URL="mongodb://127.0.0.1:27017/my_app_db"

# JWT signing secret — must be at least 32 characters (HS256)
JWT_SECRET="change-me-to-a-long-random-secret-32chars-min"

# Optional: JWT lifetime (e.g. 7d, 24h) — default applied in code if unset
JWT_EXPIRES_IN="7d"

# Password reset: when "true", POST /api/auth/forgot-password includes resetToken in JSON (dev only).
PASSWORD_RESET_RETURN_TOKEN="false"
